{
  "name": "three-player-chinese-chess",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "ai:benchmark": "AI_BENCHMARK_ENTRY=1 vite-node scripts/ai-benchmark.ts",
    "ai:tune": "vite-node scripts/ai-tune.ts",
    "ai:improve": "npm run ai:tune -- --iterations 24 --apply && npm test && npm run ai:benchmark",
    "ai:learn:loop": "vite-node scripts/ai-learn-loop.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
